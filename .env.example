# Copie para `.env` na raiz do repositório (nunca commite o `.env` real).
# Usado por `docker-compose.prod.yml` e pelo backend Django.

DEBUG=False
# SECRET_KEY: NUNCA use em produção o texto placeholder abaixo.
# Gere no servidor: python3 -c "import secrets; print(secrets.token_urlsafe(50))"
# Cole a linha INTEIRA numa única linha, sem aspas (comprimento típico 66–68 caracteres).
# Se `docker compose` mostrar sempre ~44 caracteres, veja COMMANDS.md secção 8 (override no shell).
SECRET_KEY=GERE_NO_SERVIDOR_E_SUBSTITUA_ESTA_LINHA_INTEIRA
ALLOWED_HOSTS=app.exemplo.com.br,localhost

POSTGRES_DB=saint_db
POSTGRES_USER=postgres
# Mesma senha para o Postgres (serviço db) e para o Django (DB_PASSWORD)
DB_PASSWORD=troque-por-senha-forte

DB_HOST=db
DB_PORT=5432
